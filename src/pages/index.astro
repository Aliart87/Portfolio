/* Fade animation */
.fade {
  opacity: 0;
  transform: translateY(20px);
  transition: all 0.8s ease;
}

.fade.show {
  opacity: 1;
  transform: translateY(0);
}

/* Cards */
.card {
  transition: all 0.3s ease;
}

.card:hover {
  transform: translateY(-6px);
  box-shadow: 0 20px 40px rgba(0,0,0,0.08);
}

/* Buttons */
.btn {
  transition: all 0.3s ease;
  display: inline-block;
}

.btn:hover {
  transform: scale(1.03);
}
</style>

</head>

